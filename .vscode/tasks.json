{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++: 编译当前文件",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-g",
        "-Wall",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}",
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "C++: 编译并运行当前文件",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-g",
        "-Wall",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}",
        "${file}",
        "&&",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": "$gcc"
    }
  ]
}
